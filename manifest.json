{
  "manifest_version": 3,
  "name": "Creative To-Do List",
  "version": "1.2.0",
  "description": "A creative and polished to-do list Chrome extension with animations and vibrant colors.",
  "action": {
    "default_popup": "Todo/popup.html",
    "default_icon": {
      "16": "Todo/images/icon16.png",
      "48": "Todo/images/icon48.png",
      "128": "Todo/images/icon128.png"
    }
  },
  "background": {
    "service_worker": "Todo/js/background.js"
  },
  "permissions": ["storage", "contextMenus"]
}
